{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrustTunnel",
  "version": "0.1.0",
  "identifier": "de.lenfir.trusttunnel",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TrustTunnel",
        "width": 420,
        "height": 680,
        "resizable": false,
        "visible": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray_icon.png"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/tray_icon.png"
    ]
  }
}
